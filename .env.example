# Flask/App
AUTH_ENABLED=true
AUTH_PROVIDER=google
SECRET_KEY=replace-with-a-long-random-secret
ALTKLAUSUREN_DATA_DIR=/var/lib/altklausuren
UPLOAD_LIMIT_MB=80
TRUST_PROXY_HEADERS=true

# Google Login
GOOGLE_CLIENT_ID=replace-with-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-oauth-client-secret
GOOGLE_REDIRECT_URI=https://altklausuren.forum-wi.de/auth/callback
ALLOWED_GOOGLE_DOMAIN=forum-wi.de
DRIVE_ROOT_FOLDER_ID=0AOnFniEMTZ8bUk9PVA
ADMIN_EMAILS=lukas.heinz@forum-wi.de

# Alternative hinter ForumWI Ingress/Auth Proxy:
# AUTH_PROVIDER=forward_auth
# FORWARD_AUTH_ENABLED=true
# AUTH_ROLE_VIEWER_GROUPS=Aktive,altklausuren-viewer
# AUTH_ROLE_EDITOR_GROUPS=Referat Altklausuren,altklausuren-editor
# AUTH_ROLE_ADMIN_GROUPS=Vorstand,altklausuren-admin
# AUTH_ROLE_VIEWER_ENTITLEMENTS=altklausuren:viewer
# AUTH_ROLE_EDITOR_ENTITLEMENTS=altklausuren:editor
# AUTH_ROLE_ADMIN_ENTITLEMENTS=altklausuren:admin
# FORWARD_AUTH_DEFAULT_ROLE=
#
# Nur lokal zum Testen ohne Ingress aktivieren:
# FORWARD_AUTH_DEV_ENABLED=true
# FORWARD_AUTH_DEV_EMAIL=lukas.heinz@forum-wi.de
# FORWARD_AUTH_DEV_NAME=Lukas Heinz
# FORWARD_AUTH_DEV_GROUPS=Referat Altklausuren

# Google Drive service account for server-side Drive sync
SERVICE_ACCOUNT_FILE=/var/lib/altklausuren/credentials/service_account.json
